# UAE Market Intelligence — Environment Variables

# Server port (default: 8000)
PORT=8000

# SQLite database path inside the container (default: /app/data/market_intel.db)
DATABASE_PATH=/app/data/market_intel.db

# Scraping pipeline API keys
APIFY_TOKEN=your_apify_token_here
TAVILY_API_KEY=your_tavily_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Max items per source per scrape run (default: 20)
SCRAPE_MAX_ITEMS_PER_SOURCE=20

# SSO shared secret — must be identical across ALL aldhaheri.co project repos
JWT_SECRET=your-shared-jwt-secret-must-be-same-across-all-repos
