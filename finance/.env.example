# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Webhook security — generate with: openssl rand -hex 32
WEBHOOK_API_KEY=your-secret-key-here

# Dashboard login credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password

# JWT signing secret — MUST be the same across all aldhaheri.co SSO repos
# Generate with: openssl rand -hex 32
JWT_SECRET=your-shared-jwt-secret-must-be-same-across-all-repos

# Telegram notifications
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Frontend (used at build time by Vite)
VITE_API_URL=https://finance.YOURDOMAIN.com
VITE_API_KEY=your-secret-key-here
