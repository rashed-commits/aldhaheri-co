# ── Shared SSO (MUST be identical across all services) ────────────────────────
JWT_SECRET=your-shared-jwt-secret

# ── Hub ───────────────────────────────────────────────────────────────────────
HUB_USERNAME=admin
HUB_PASSWORD=changeme
VITE_API_URL=https://aldhaheri.co

# ── Finance ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
WEBHOOK_API_KEY=your-webhook-api-key
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme
FINANCE_VITE_API_URL=https://finance.yourdomain.com
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHATBOT_TOKEN=your-chatbot-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Market Intel ──────────────────────────────────────────────────────────────
PORT=8000
DATABASE_PATH=/app/data/market_intel.db
SCRAPE_MAX_ITEMS_PER_SOURCE=20

# ── Real Estate ───────────────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
SENDER_EMAIL=your-verified-sender@example.com
REPORT_RECIPIENT=you@example.com

# ── Trade Bot ─────────────────────────────────────────────────────────────────
# Trade Bot is discontinued (2026-05-15). These vars are unused.
ALPACA_API_KEY=your-alpaca-key
ALPACA_SECRET_KEY=your-alpaca-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
FINNHUB_API_KEY=your-finnhub-key

# ── Agents ────────────────────────────────────────────────────────────────────
# Reuses ANTHROPIC_API_KEY (chat + reflection), JWT_SECRET (SSO),
# TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID (cron output delivery).
# Optional override:
# AGENTS_DB_PATH=/data/agents.db
