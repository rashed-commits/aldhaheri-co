# UAE Real Estate Monitor Bot — Environment Variables
# Copy this file to .env and fill in your values.
# The bot reads these via os.getenv() in config.py.

# ─── Brevo Transactional Email API ───────────────────────────────────
# 1. Sign up free at https://app.brevo.com
# 2. Get API key: Settings → API Keys (starts with xkeysib-)
# 3. Verify sender email: Settings → Senders & IP → Add a Sender
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=your-verified-sender@example.com

# ─── Report recipient ─────────────────────────────────────────────────────
REPORT_RECIPIENT=rashed@aldhaheri.co

# ─── SSO (shared across all aldhaheri.co services) ───────────────────────
JWT_SECRET=your-shared-jwt-secret-here
